# Application
APP_ENV=development
TZ=Europe/Madrid
APP_TIMEZONE=Europe/Madrid
DATABASE_URL=sqlite:///./data/ainvestor.db
TRADING_MODE=paper
PAPER_INITIAL_BALANCE=100.0
PAPER_QUOTE_CURRENCY=USDT

# Exchange (read-only for paper; trading keys for testnet/live)
BINANCE_API_KEY=
BINANCE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
DEFAULT_EXCHANGE=binance

# AI - Cursor SDK (Composer 2.5)
# AI_MODEL is the model id only. Billing variant is controlled via SDK param fast=false
# (default). Set AI_USE_FAST=true only if you explicitly want composer-2.5-fast.
CURSOR_API_KEY=
AI_MODEL=composer-2.5
AI_USE_FAST=false
# MCP via Cursor bridge needs Node; keep false in Docker unless you need tools.
AI_USE_MCP=false

# Data sources
CRYPTOPANIC_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ainvestor/0.1

# Scheduler intervals (minutes)
# AI cycle per profile: config/risk.yaml → ai_cycle_interval_minutes
# Per-profile AI cycle intervals in config/risk.yaml (aggressive 90, extreme 30).
# AI_CYCLE_INTERVAL is fallback only.
RISK_MONITOR_INTERVAL=5
MARKET_COLLECT_INTERVAL=15
AI_CYCLE_INTERVAL=120

# Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Live mode safety (hardcoded cap)
LIVE_MAX_CAPITAL_EUR=100.0
LIVE_MAX_CRYPTO_EUR=50.0
LIVE_MAX_STOCKS_EUR=50.0
LIVE_MAX_DERIVATIVES_EUR=25.0

# Stocks: paper | ibkr_paper | ibkr_live
STOCK_TRADING_MODE=paper

# IBKR (optional — pip install ainvestor[ibkr])
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
