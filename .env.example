# Application
APP_ENV=development
TZ=Europe/Madrid
APP_TIMEZONE=Europe/Madrid
DATABASE_URL=sqlite:///./data/ainvestor.db
TRADING_MODE=paper
PAPER_INITIAL_BALANCE=100.0
PAPER_QUOTE_CURRENCY=USDT

# Exchange (read-only for paper; trading keys for testnet/live)
BINANCE_API_KEY=
BINANCE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
DEFAULT_EXCHANGE=binance

# AI - Cursor SDK (Composer 2.5)
CURSOR_API_KEY=
AI_MODEL=composer-2.5
AI_USE_FAST=false
AI_FALLBACK_ENABLED=true

# AI - OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Data sources
CRYPTOPANIC_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ainvestor/0.1

# Scheduler intervals (minutes)
RISK_MONITOR_INTERVAL=5
MARKET_COLLECT_INTERVAL=15
AI_CYCLE_INTERVAL=60

# Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Live mode safety (hardcoded cap)
LIVE_MAX_CAPITAL_EUR=100.0
LIVE_MAX_CRYPTO_EUR=50.0
LIVE_MAX_STOCKS_EUR=50.0
LIVE_MAX_DERIVATIVES_EUR=25.0

# Stocks: paper | ibkr_paper | ibkr_live
STOCK_TRADING_MODE=paper

# IBKR (optional — pip install ainvestor[ibkr])
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
